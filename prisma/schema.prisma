// ===================================
// Prisma Schema - JoyNatura
// Base de datos PostgreSQL para gestión de clientes
// ===================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Clientes de JoyNatura
model Cliente {
  id               String   @id @default(cuid())
  nombre           String
  tipo             String   @default("local")
  telefono         String   @default("")
  email            String   @default("")
  calle            String   @default("")
  numero           String   @default("")
  colonia          String   @default("")
  ciudad           String   @default("")
  estado           String   @default("")
  fechaCreacion    DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  @@map("clientes")
}

/// Catálogo de productos JoyNatura con precios mayoreo y menudeo
model Producto {
  id              String   @id @default(cuid())
  numero          Int      @unique
  nombre          String
  precioMayoreo   Float    @map("precio_mayoreo")
  precioMenudeo   Float    @map("precio_menudeo")
  fechaCreacion   DateTime @default(now()) @map("fecha_creacion")

  @@map("productos")
}
